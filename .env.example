# CROO public discovery API (no auth) — used to resolve serviceIds + schemas
CROO_PUBLIC_API=https://api.croo.network/backend/v1/public

# CROO runtime (agent) — from the Agent Store dashboard after registering Capo
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
CROO_SDK_KEY=croo_sk_xxx
BASE_RPC_URL=https://mainnet.base.org

# Synthesis: set EITHER OpenAI or Anthropic (or both). Both blank = deterministic fallback.
# CAPO_SYNTH_PROVIDER: auto (default; prefers Anthropic if both set) | openai | anthropic
CAPO_SYNTH_PROVIDER=auto
OPENAI_API_KEY=sk-...
CAPO_OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=sk-ant-...
CAPO_SYNTH_MODEL=claude-haiku-4-5
